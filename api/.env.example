# Spotify
SPOTIFY_ID=spotify_id_here
SPOTIFY_SECRET=spotify_secret_here
SPOTIFY_USERNAME=spotify_username_here
SPOTIFY_REDIRECT=http://127.0.0.1:5001/auth/callback

# OpenAI
GPT_KEY=gpt_key_here

# Flask
SECRET_KEY=very_long_random_key_here
FRONTEND_URL=http://127.0.0.1:5001
PORT=5001

# Base de données (laisser vide en dev = SQLite local)
# En prod, mettre l'URL de connexion Supabase (Settings > Database > Connection string > Transaction pooler)
# Format : postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Whitelist Spotify user IDs (vide = tout le monde autorisé)
# Séparés par des virgules : user1,user2,user3
ALLOWED_USERS=
